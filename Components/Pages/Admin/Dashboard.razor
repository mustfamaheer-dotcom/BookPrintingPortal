@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin")]
@inject AppDbContext Db
@inject PrintLoggingService PrintLogging

<div class="content-area dashboard-page">
    <div class="page-header">
        <div>
            <h1>Dashboard</h1>
            <p class="page-subtitle">Overview of your printing management system</p>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3 col-6">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-bg"></div>
                <div class="stat-card-inner">
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-label">Total Books</div>
                        <div class="stat-value">@totalBooks</div>
                    </div>
                    <div class="stat-trend stat-trend-up">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card stat-card-success">
                <div class="stat-card-bg"></div>
                <div class="stat-card-inner">
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-label">Active Shops</div>
                        <div class="stat-value">@activeShops</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card stat-card-purple">
                <div class="stat-card-bg"></div>
                <div class="stat-card-inner">
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-label">Boards</div>
                        <div class="stat-value">@totalBoards</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card stat-card-warning">
                <div class="stat-card-bg"></div>
                <div class="stat-card-inner">
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-label">Total Prints</div>
                        <div class="stat-value">@totalPrints</div>
                    </div>
                    <div class="stat-trend stat-trend-up">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="content-card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5>Recent Print Activity</h5>
                    <a href="/admin/analytics" class="btn btn-sm btn-header-link">View All</a>
                </div>
                <div class="card-body p-0">
                    @if (recentLogs == null)
                    {
                        <div class="loading-placeholder">Loading...</div>
                    }
                    else if (!recentLogs.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="1.5" stroke-linecap="round"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/></svg>
                            </div>
                            <p>No print activity yet</p>
                        </div>
                    }
                    else
                    {
                        <div class="activity-timeline">
                            @foreach (var log in recentLogs)
                            {
                                <div class="timeline-item">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-content">
                                        <div class="timeline-header">
                                            <span class="timeline-shop">@log.ShopName</span>
                                            <span class="timeline-time">@log.PrintedAt.ToEgyptLocal().ToString("g")</span>
                                        </div>
                                        <div class="timeline-body">
                                            <span class="timeline-book">@log.BookTitle</span>
                                            <span class="timeline-badge">
                                                <strong>@log.Copies</strong> cop@(log.Copies == 1 ? "y" : "ies")
                                            </span>
                                        </div>
                                        <div class="timeline-footer">
                                            <span class="timeline-user">by @log.PrintedByUserName</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="content-card">
                <div class="card-header"><h5>Quick Actions</h5></div>
                <div class="card-body">
                    <div class="quick-actions">
                        <a href="/admin/books" class="quick-action-item">
                            <div class="quick-action-icon" style="background: var(--primary-light); color: var(--primary);">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                            </div>
                            <div>
                                <div class="quick-action-label">Upload New Book</div>
                                <div class="quick-action-desc">Add a new book to the system</div>
                            </div>
                        </a>
                        <a href="/admin/shops" class="quick-action-item">
                            <div class="quick-action-icon" style="background: #ecfdf5; color: var(--success);">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            </div>
                            <div>
                                <div class="quick-action-label">Add Bookshop</div>
                                <div class="quick-action-desc">Register a new shop account</div>
                            </div>
                        </a>
                        <a href="/admin/assignments" class="quick-action-item">
                            <div class="quick-action-icon" style="background: #fef3c7; color: var(--warning);">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M8 7h8"/><path d="M8 11h6"/></svg>
                            </div>
                            <div>
                                <div class="quick-action-label">Book Access</div>
                                <div class="quick-action-desc">Link books to shops</div>
                            </div>
                        </a>
                        <a href="/admin/users" class="quick-action-item">
                            <div class="quick-action-icon" style="background: #ede9fe; color: #7c3aed;">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </div>
                            <div>
                                <div class="quick-action-label">Manage Users</div>
                                <div class="quick-action-desc">Add or manage portal users</div>
                            </div>
                        </a>
                        <a href="/admin/analytics" class="quick-action-item">
                            <div class="quick-action-icon" style="background: #f3e8ff; color: #7c3aed;">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                            </div>
                            <div>
                                <div class="quick-action-label">View Analytics</div>
                                <div class="quick-action-desc">Check printing statistics</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalBooks;
    private int activeShops;
    private int totalBoards;
    private int totalPrints;
    private List<PrintLog>? recentLogs;

    protected override async Task OnInitializedAsync()
    {
        totalBooks = await Db.Books.CountAsync(b => b.IsActive);
        activeShops = await Db.Shops.CountAsync(s => s.IsActive);
        totalBoards = await Db.EducationalBoards.CountAsync(b => b.IsActive);
        totalPrints = await PrintLogging.GetTotalPrintsAsync();
        recentLogs = await PrintLogging.GetRecentLogsAsync(20);
    }
}

@page "/admin/boards"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject NavigationManager Navigation

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>Educational Boards</h1>
            <p class="page-subtitle">Manage educational boards and categories</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>@message</span>
            <button type="button" class="btn-close ms-auto" @onclick="() => message = null"></button>
        </div>
    }

    <div class="content-card mb-4">
        <div class="card-header">
            <h5>@(editing ? "Edit Board" : "Add New Board")</h5>
        </div>
        <div class="card-body">
            <EditForm Model="@editModel" OnValidSubmit="@SaveBoard">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Board Name</label>
                        <InputText @bind-Value="editModel.Name" class="form-control" placeholder="Enter board name" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Description</label>
                        <InputText @bind-Value="editModel.Description" class="form-control" placeholder="Optional description" />
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">@(editing ? "Update Board" : "Create Board")</button>
                    @if (editing)
                    {
                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CancelEdit">Cancel</button>
                    }
                </div>
            </EditForm>
        </div>
    </div>

    <div class="content-card">
        <div class="card-body p-0">
            @if (boards == null)
            {
                <div class="loading-placeholder">Loading...</div>
            }
            else
            {
                <div class="table-container">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Books</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var board in boards)
                            {
                                <tr>
                                    <td>@board.Id</td>
                                    <td><strong>@board.Name</strong></td>
                                    <td>@board.Description</td>
                                    <td>
                                        <span class="badge @(board.IsActive ? "bg-success" : "bg-secondary")">
                                            @(board.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>@board.Books?.Count ?? 0</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditBoard(board)">Edit</button>
                                        <button class="btn btn-sm btn-outline-warning" @onclick="() => ToggleBoard(board)">@(board.IsActive ? "Deactivate" : "Activate")</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<EducationalBoard>? boards;
    private BoardEditModel editModel = new();
    private bool editing;
    private int editingId;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadBoards();
    }

    private async Task LoadBoards()
    {
        boards = await Db.EducationalBoards.OrderBy(b => b.Name).Include(b => b.Books).ToListAsync();
    }

    private void EditBoard(EducationalBoard board)
    {
        editing = true;
        editingId = board.Id;
        editModel.Name = board.Name;
        editModel.Description = board.Description;
    }

    private void CancelEdit()
    {
        editing = false;
        editingId = 0;
        editModel = new();
    }

    private async Task SaveBoard()
    {
        if (editing)
        {
            var board = await Db.EducationalBoards.FindAsync(editingId);
            if (board != null)
            {
                board.Name = editModel.Name;
                board.Description = editModel.Description;
                message = "Board updated successfully.";
            }
        }
        else
        {
            Db.EducationalBoards.Add(new EducationalBoard
            {
                Name = editModel.Name,
                Description = editModel.Description
            });
            message = "Board created successfully.";
        }

        await Db.SaveChangesAsync();
        await LoadBoards();
        CancelEdit();
    }

    private async Task ToggleBoard(EducationalBoard board)
    {
        board.IsActive = !board.IsActive;
        await Db.SaveChangesAsync();
        await LoadBoards();
    }

    private class BoardEditModel
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
    }
}
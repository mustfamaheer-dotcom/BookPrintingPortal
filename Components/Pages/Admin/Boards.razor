@page "/admin/boards"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject NavigationManager Navigation

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>Educational Boards</h1>
            <p class="page-subtitle">Manage educational boards and categories</p>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-primary" @onclick="() => { editing = false; editModel = new(); error = null; }" data-bs-toggle="modal" data-bs-target="#boardModal">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Board
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-modern alert-success">@message</div>
    }

    @* Board Modal *@
    <div class="modal-overlay @(showModal ? "show" : "")" @onclick="() => showModal = false">
        <div class="modal-container" @onclick:stopPropagation>
            <div class="modal-header">
                <h5 class="modal-title">@(editing ? "Edit Board" : "Add New Board")</h5>
                <button type="button" class="modal-close" @onclick="() => showModal = false">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger mb-3">@error</div>
                }
                <EditForm Model="@editModel" OnValidSubmit="@SaveBoard">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Board Name</label>
                        <InputText @bind-Value="editModel.Name" class="form-control form-control-modern" placeholder="e.g. Cambridge, Edexcel" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <InputText @bind-Value="editModel.Description" class="form-control form-control-modern" placeholder="Optional description" />
                    </div>
                    <div class="modal-actions">
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => showModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            @(editing ? "Update Board" : "Create Board")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="content-card">
        <div class="card-body p-0">
            @if (boards == null)
            {
                <div class="loading-placeholder">Loading...</div>
            }
            else if (!boards.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                    </div>
                    <p>No boards created yet</p>
                </div>
            }
            else
            {
                <div class="table-container">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Books</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var board in boards)
                            {
                                <tr>
                                    <td><strong>@board.Name</strong></td>
                                    <td class="text-muted">@board.Description</td>
                                    <td>
                                        <span class="status-badge @(board.IsActive ? "status-active" : "status-inactive")">
                                            <span class="status-dot"></span>
                                            @(board.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td><span class="count-badge">@(board.Books?.Count ?? 0)</span></td>
                                    <td class="text-end">
                                        <div class="action-btns">
                                            <button class="btn-icon btn-icon-edit" title="Edit" @onclick="() => { EditBoard(board); showModal = true; }">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            <button class="btn-icon btn-icon-toggle" title="@(board.IsActive ? "Deactivate" : "Activate")" @onclick="() => ToggleBoard(board)">
                                                @if (board.IsActive)
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                                }
                                                else
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                                }
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<EducationalBoard>? boards;
    private BoardEditModel editModel = new();
    private bool editing;
    private int editingId;
    private bool showModal;
    private string? message;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadBoards();
    }

    private async Task LoadBoards()
    {
        boards = await Db.EducationalBoards.OrderBy(b => b.Name).Include(b => b.Books).ToListAsync();
    }

    private void EditBoard(EducationalBoard board)
    {
        editing = true;
        editingId = board.Id;
        editModel.Name = board.Name;
        editModel.Description = board.Description;
        error = null;
    }

    private async Task SaveBoard()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(editModel.Name))
        {
            error = "Board name is required.";
            return;
        }

        if (editing)
        {
            var board = await Db.EducationalBoards.FindAsync(editingId);
            if (board != null)
            {
                board.Name = editModel.Name;
                board.Description = editModel.Description;
                message = "Board updated successfully.";
            }
        }
        else
        {
            Db.EducationalBoards.Add(new EducationalBoard
            {
                Name = editModel.Name,
                Description = editModel.Description
            });
            message = "Board created successfully.";
        }

        await Db.SaveChangesAsync();
        await LoadBoards();
        showModal = false;
        editModel = new();
        editing = false;
    }

    private async Task ToggleBoard(EducationalBoard board)
    {
        board.IsActive = !board.IsActive;
        await Db.SaveChangesAsync();
        await LoadBoards();
    }

    private class BoardEditModel
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
    }
}

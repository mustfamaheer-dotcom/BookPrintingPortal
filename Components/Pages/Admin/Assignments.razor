@page "/admin/assignments"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject NavigationManager Navigation

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>Assign Books to Shops</h1>
            <p class="page-subtitle">Manage which books are available to each bookshop</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>@message</span>
            <button type="button" class="btn-close ms-auto" @onclick="() => message = null"></button>
        </div>
    }

    <div class="row g-4">
        @if (shops != null)
        {
            @foreach (var shop in shops.Where(s => s.IsActive))
            {
                <div class="col-md-6">
                    <div class="content-card">
                        <div class="card-header">
                            <h5 class="mb-0">@shop.Name</h5>
                        </div>
                        <div class="card-body">
                            @if (books != null)
                            {
                                @foreach (var book in books.Where(b => b.IsActive))
                                {
                                    var isAssigned = assignedBooks.ContainsKey($"{shop.Id}-{book.Id}");
                                    <div class="form-check mb-2">
                                        <input type="checkbox" class="form-check-input"
                                               id="assign-@shop.Id-@book.Id"
                                               checked="@isAssigned"
                                               @onchange="e => ToggleAssignment(shop.Id, book.Id, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label" for="assign-@shop.Id-@book.Id">
                                            <strong>@book.Title</strong>
                                            <small class="text-muted"> (@book.Board?.Name)</small>
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<Shop>? shops;
    private List<Book>? books;
    private Dictionary<string, bool> assignedBooks = new();
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        shops = await Db.Shops.OrderBy(s => s.Name).ToListAsync<Shop>();
        books = await Db.Books.Include(b => b.Board).OrderBy(b => b.Title).ToListAsync<Book>();
        var assignments = await Db.ShopBookAssignments.Where(a => a.IsActive).ToListAsync<ShopBookAssignment>();

        assignedBooks = new Dictionary<string, bool>();
        foreach (var a in assignments)
            assignedBooks[$"{a.ShopId}-{a.BookId}"] = true;
    }

    private async Task ToggleAssignment(int shopId, int bookId, bool assigned)
    {
        var existing = await Db.ShopBookAssignments
            .FirstOrDefaultAsync(a => a.ShopId == shopId && a.BookId == bookId);

        if (assigned && existing == null)
        {
            Db.ShopBookAssignments.Add(new ShopBookAssignment
            {
                ShopId = shopId,
                BookId = bookId
            });
        }
        else if (!assigned && existing != null)
        {
            Db.ShopBookAssignments.Remove(existing);
        }

        await Db.SaveChangesAsync();
        assignedBooks[$"{shopId}-{bookId}"] = assigned;
        message = "Assignment updated.";
    }
}
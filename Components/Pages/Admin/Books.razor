@page "/admin/books"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject FileStorageService FileStorage
@inject NavigationManager Navigation

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>Books</h1>
            <p class="page-subtitle">Manage educational books and upload PDFs</p>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-primary" @onclick="() => showUpload = !showUpload">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Upload Book
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-modern alert-success">@message</div>
    }
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-modern alert-danger">@error</div>
    }

    @if (showUpload)
    {
        <div class="upload-card mb-4">
            <div class="upload-card-header">
                <div class="d-flex align-items-center gap-2">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <h5 class="mb-0">Upload New Book</h5>
                </div>
                <button type="button" class="modal-close" @onclick="() => showUpload = false">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="upload-card-body">
                <EditForm Model="@uploadModel" OnValidSubmit="@UploadBook">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Book Title</label>
                            <InputText @bind-Value="uploadModel.Title" class="form-control form-control-modern" placeholder="Enter book title" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Educational Board</label>
                            <select class="form-select form-control-modern" @bind="uploadModel.BoardId">
                                <option value="0">-- Select Board --</option>
                                @foreach (var board in boards)
                                {
                                    <option value="@board.Id">@board.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Page Count</label>
                            <InputNumber @bind-Value="uploadModel.PageCount" class="form-control form-control-modern" />
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label">PDF File</label>
                        <div class="file-drop-zone" @ondragover="() => {}" @ondrop="() => {}">
                            <InputFile OnChange="@OnFileSelected" accept=".pdf" id="pdfUpload" class="file-input-hidden" />
                            <label for="pdfUpload" class="file-drop-label">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                                <span>@(selectedFileName ?? "Click to select a PDF file")</span>
                            </label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" disabled="@loading">
                        @if (loading)
                        {
                            <span class="loading-spinner me-1"></span>
                        }
                        @(loading ? "Uploading..." : "Upload Book")
                    </button>
                </EditForm>
            </div>
        </div>
    }

    @* Delete Confirmation Modal *@
    <div class="modal-overlay @(showDeleteModal ? "show" : "")" @onclick="() => showDeleteModal = false">
        <div class="modal-container modal-sm" @onclick:stopPropagation>
            <div class="modal-body text-center py-4">
                <div class="delete-icon mb-3">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="1.5"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </div>
                <h5 class="mb-2">Delete Book</h5>
                <p class="text-muted mb-3">Are you sure you want to delete <strong>@deletingBook?.Title</strong>?</p>
                <div class="modal-actions justify-content-center">
                    <button class="btn btn-outline-secondary" @onclick="() => showDeleteModal = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <div class="content-card">
        <div class="card-body p-0">
            @if (books == null)
            {
                <div class="loading-placeholder">Loading...</div>
            }
            else if (!books.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    </div>
                    <p>No books uploaded yet</p>
                </div>
            }
            else
            {
                <div class="table-container">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Board</th>
                                <th>Size</th>
                                <th>Pages</th>
                                <th>Status</th>
                                <th>Uploaded</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var book in books)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="book-icon">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                                            </div>
                                            <strong>@book.Title</strong>
                                        </div>
                                    </td>
                                    <td><span class="board-tag">@book.Board?.Name</span></td>
                                    <td>@FormatSize(book.FileSizeBytes)</td>
                                    <td><span class="count-badge">@book.PageCount</span></td>
                                    <td>
                                        <span class="status-badge @(book.IsActive ? "status-active" : "status-inactive")">
                                            <span class="status-dot"></span>
                                            @(book.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-muted">@book.CreatedAt.ToLocalTime().ToString("d")</td>
                                    <td class="text-end">
                                        <div class="action-btns">
                                            <button class="btn-icon btn-icon-danger" title="Delete" @onclick="() => { deletingBook = book; showDeleteModal = true; }">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Book>? books;
    private List<EducationalBoard> boards = new();
    private BookUploadModel uploadModel = new();
    private IBrowserFile? selectedFile;
    private string? selectedFileName;
    private bool loading;
    private bool showUpload;
    private bool showDeleteModal;
    private Book? deletingBook;
    private string? message;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        boards = await Db.EducationalBoards.Where(b => b.IsActive).ToListAsync<EducationalBoard>();
        books = await Db.Books.Include(b => b.Board).OrderByDescending(b => b.CreatedAt).ToListAsync<Book>();
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = e.File?.Name;
    }

    private async Task UploadBook()
    {
        error = null;
        loading = true;

        try
        {
            if (uploadModel.BoardId == 0)
            {
                error = "Please select a board.";
                return;
            }

            if (selectedFile == null)
            {
                error = "Please select a PDF file.";
                return;
            }

            if (!selectedFile.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
            {
                error = "Only PDF files are allowed.";
                return;
            }

            var tempPath = Path.Combine(Path.GetTempPath(), $"{Guid.NewGuid():N}.pdf");
            await using (var stream = new FileStream(tempPath, FileMode.Create))
            {
                await selectedFile.OpenReadStream(100 * 1024 * 1024).CopyToAsync(stream);
            }

            var finalFileName = $"{Guid.NewGuid():N}.pdf";
            var booksDir = Path.Combine(Directory.GetCurrentDirectory(), "App_Data", "Books");
            Directory.CreateDirectory(booksDir);
            var finalPath = Path.Combine(booksDir, finalFileName);
            System.IO.File.Move(tempPath, finalPath);

            var book = new Book
            {
                Title = uploadModel.Title,
                BoardId = uploadModel.BoardId,
                FilePath = finalFileName,
                OriginalFileName = selectedFile.Name,
                FileSizeBytes = new FileInfo(finalPath).Length,
                PageCount = uploadModel.PageCount
            };

            Db.Books.Add(book);
            await Db.SaveChangesAsync();

            message = $"Book '{uploadModel.Title}' uploaded successfully.";
            uploadModel = new();
            selectedFile = null;
            selectedFileName = null;
            showUpload = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            error = $"Upload failed: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ConfirmDelete()
    {
        if (deletingBook == null) return;
        Db.Books.Remove(deletingBook);
        var filePath = Path.Combine(Directory.GetCurrentDirectory(), "App_Data", "Books", deletingBook.FilePath);
        if (System.IO.File.Exists(filePath))
            System.IO.File.Delete(filePath);
        await Db.SaveChangesAsync();
        await LoadData();
        message = $"Book '{deletingBook.Title}' deleted.";
        showDeleteModal = false;
        deletingBook = null;
    }

    private static string FormatSize(long bytes)
    {
        return bytes switch
        {
            >= 1_000_000 => $"{bytes / 1_000_000.0:F1} MB",
            >= 1_000 => $"{bytes / 1_000.0:F1} KB",
            _ => $"{bytes} B"
        };
    }

    private class BookUploadModel
    {
        public string Title { get; set; } = "";
        public int BoardId { get; set; }
        public int PageCount { get; set; }
    }
}

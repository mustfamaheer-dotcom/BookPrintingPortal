@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager Navigation

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>Users</h1>
            <p class="page-subtitle">Manage all portal users and their roles</p>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-primary" @onclick="OpenCreate">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add User
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-modern alert-success">@message</div>
    }
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-modern alert-danger">@error</div>
    }

    @* Create/Edit Modal *@
    <div class="modal-overlay @(showModal ? "show" : "")" @onclick="() => showModal = false">
        <div class="modal-container" @onclick:stopPropagation>
            <div class="modal-header">
                <h5 class="modal-title">@(editing ? "Edit User" : "Add New User")</h5>
                <button type="button" class="modal-close" @onclick="() => showModal = false">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input @bind="editEmail" type="email" class="form-control form-control-modern" placeholder="Email address" required disabled="@editing" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input @bind="editFullName" class="form-control form-control-modern" placeholder="Full name" />
                </div>
                @if (!editing)
                {
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input @bind="editPassword" type="password" class="form-control form-control-modern" placeholder="Password" required />
                    </div>
                }
                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <select @bind="editRole" class="form-control form-control-modern" @bind:after="OnRoleBound">
                        <option value="">-- Select Role --</option>
                        @foreach (var r in roles)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>
                @if (editRole == "Shop")
                {
                    <div class="mb-3">
                        <label class="form-label">Shop</label>
                        <select @bind="editShopId" class="form-control form-control-modern">
                            <option value="">-- Select Shop --</option>
                            @foreach (var s in shops)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                        @if (!editing)
                        {
                            <small class="text-muted">Need a shop? <a href="/admin/shops">Create one first</a>.</small>
                        }
                    </div>
                }
                <div class="modal-actions">
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => showModal = false">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveUser">@(editing ? "Update" : "Create")</button>
                </div>
            </div>
        </div>
    </div>

    @* Delete Confirmation *@
    <div class="modal-overlay @(showDeleteModal ? "show" : "")" @onclick="() => showDeleteModal = false">
        <div class="modal-container modal-sm" @onclick:stopPropagation>
            <div class="modal-body text-center py-4">
                <div class="delete-icon mb-3">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="1.5"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </div>
                <h5 class="mb-2">Delete User</h5>
                <p class="text-muted mb-3">Are you sure you want to delete <strong>@deletingEmail</strong>?</p>
                <div class="modal-actions justify-content-center">
                    <button class="btn btn-outline-secondary" @onclick="() => showDeleteModal = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <div class="content-card">
        <div class="card-body p-0">
            @if (users == null)
            {
                <div class="loading-placeholder">Loading...</div>
            }
            else
            {
                <div class="table-container">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Shop</th>
                                <th>Email Confirmed</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in users)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="user-avatar">
                                                @u.Email.Substring(0, 1).ToUpper()
                                            </div>
                                            <strong>@u.Email</strong>
                                        </div>
                                    </td>
                                    <td>@u.FullName</td>
                                    <td>
                                        <span class="role-badge @(u.Role == "Admin" ? "role-admin" : "role-shop")">@u.Role</span>
                                    </td>
                                    <td>@(u.ShopName ?? "-")</td>
                                    <td>
                                        @if (u.EmailConfirmed)
                                        {
                                            <span class="status-badge status-active"><span class="status-dot"></span> Yes</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive"><span class="status-dot"></span> No</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="action-btns">
                                            <button class="btn-icon btn-icon-edit" title="Edit" @onclick="() => OpenEdit(u)">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            <button class="btn-icon btn-icon-danger" title="Delete" @onclick="() => { deletingUserId = u.Id; deletingEmail = u.Email; showDeleteModal = true; }">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<UserViewModel>? users;
    private List<string> roles = [];
    private List<Shop>? shops;
    private bool showModal;
    private bool editing;
    private string? message;
    private string? error;

    private string editEmail = "";
    private string editFullName = "";
    private string editPassword = "";
    private string editRole = "";
    private int? editShopId;
    private string? editingUserId;

    private bool showDeleteModal;
    private string? deletingUserId;
    private string? deletingEmail;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        shops = await Db.Shops.OrderBy(s => s.Name).ToListAsync();
        roles = (await RoleManager.Roles.Select(r => r.Name).ToListAsync())!;
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        var appUsers = await UserManager.Users.Include(u => u.Shop).OrderBy(u => u.Email).ToListAsync();
        users = [];
        foreach (var u in appUsers)
        {
            var userRoles = await UserManager.GetRolesAsync(u);
            users.Add(new UserViewModel
            {
                Id = u.Id,
                Email = u.Email ?? "",
                FullName = u.FullName ?? "",
                Role = userRoles.FirstOrDefault() ?? "None",
                ShopName = u.Shop?.Name,
                EmailConfirmed = u.EmailConfirmed
            });
        }
    }

    private void OpenCreate()
    {
        editing = false;
        editEmail = "";
        editFullName = "";
        editPassword = "";
        editRole = "";
        editShopId = null;
        editingUserId = null;
        error = null;
        showModal = true;
    }

    private void OpenEdit(UserViewModel u)
    {
        editing = true;
        editingUserId = u.Id;
        editEmail = u.Email;
        editFullName = u.FullName;
        editPassword = "";
        editRole = u.Role;
                    editShopId = u.Role == "Shop" ? shops?.FirstOrDefault(s => s.Name == u.ShopName)?.Id : null;
        error = null;
        showModal = true;
    }

    private void OnRoleBound()
    {
        if (editRole != "Shop")
            editShopId = null;
    }

    private async Task SaveUser()
    {
        error = null;

        if (editing)
        {
            var user = await UserManager.FindByIdAsync(editingUserId!);
            if (user == null) { error = "User not found."; return; }

            user.FullName = editFullName;
            var updateResult = await UserManager.UpdateAsync(user);
            if (!updateResult.Succeeded)
            {
                error = string.Join(", ", updateResult.Errors.Select(e => e.Description));
                return;
            }

            var currentRoles = await UserManager.GetRolesAsync(user);
            await UserManager.RemoveFromRolesAsync(user, currentRoles);
            if (!string.IsNullOrEmpty(editRole))
                await UserManager.AddToRoleAsync(user, editRole);

            if (editRole == "Shop")
            {
                user.ShopId = editShopId;
                await UserManager.UpdateAsync(user);
            }
            else
            {
                user.ShopId = null;
                await UserManager.UpdateAsync(user);
            }

            message = $"User '{editEmail}' updated.";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(editEmail) || string.IsNullOrWhiteSpace(editPassword))
            {
                error = "Email and password are required.";
                return;
            }
            if (string.IsNullOrWhiteSpace(editRole))
            {
                error = "Please select a role.";
                return;
            }
            if (editRole == "Shop" && editShopId == null)
            {
                error = "Please select a shop for this user.";
                return;
            }

            var existing = await UserManager.FindByEmailAsync(editEmail);
            if (existing != null) { error = "A user with this email already exists."; return; }

            var user = new ApplicationUser
            {
                UserName = editEmail,
                Email = editEmail,
                FullName = editFullName,
                ShopId = editRole == "Shop" ? editShopId : null,
                EmailConfirmed = true
            };

            var result = await UserManager.CreateAsync(user, editPassword);
            if (!result.Succeeded)
            {
                error = string.Join(", ", result.Errors.Select(e => e.Description));
                return;
            }

            await UserManager.AddToRoleAsync(user, editRole);
            message = $"User '{editEmail}' created with role '{editRole}'.";
        }

        await LoadUsers();
        showModal = false;
    }

    private async Task ConfirmDelete()
    {
        if (deletingUserId == null) return;
        var user = await UserManager.FindByIdAsync(deletingUserId);
        if (user != null)
        {
            var result = await UserManager.DeleteAsync(user);
            if (result.Succeeded)
                message = $"User '{deletingEmail}' deleted.";
            else
                error = string.Join(", ", result.Errors.Select(e => e.Description));
        }
        await LoadUsers();
        showDeleteModal = false;
        deletingUserId = null;
        deletingEmail = null;
    }

    private class UserViewModel
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Role { get; set; } = "";
        public string? ShopName { get; set; }
        public bool EmailConfirmed { get; set; }
    }
}

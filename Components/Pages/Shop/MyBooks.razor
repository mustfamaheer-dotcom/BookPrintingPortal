@page "/shop/mybooks"
@attribute [Authorize(Roles = "Shop")]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>My Assigned Books</h1>
            <p class="page-subtitle">Browse and print books assigned to your shop</p>
        </div>
    </div>

    @if (error != null)
    {
        <div class="alert alert-modern alert-danger">@error</div>
    }

    @if (booksByBoard == null)
    {
        <div class="row g-4">
            @for (int i = 0; i < 6; i++)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="book-card-skeleton">
                        <div class="skeleton-line skeleton-title"></div>
                        <div class="skeleton-line skeleton-text"></div>
                        <div class="skeleton-line skeleton-btn"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!booksByBoard.Any())
    {
        <div class="empty-state py-5">
            <div class="empty-icon mb-3">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <h5 class="text-muted">No Books Assigned</h5>
            <p>No books have been assigned to your shop yet. Please contact the administrator.</p>
        </div>
    }
    else
    {
        @foreach (var group in booksByBoard)
        {
            <div class="board-section mb-4">
                <div class="board-section-header">
                    <div class="board-section-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                    </div>
                    <h4 class="board-section-title">@group.BoardName</h4>
                    <span class="board-section-count">@group.Books.Count book@(group.Books.Count == 1 ? "" : "s")</span>
                </div>
                <div class="row g-3 mt-1">
                    @foreach (var book in group.Books)
                    {
                        <div class="col-md-4 col-lg-3">
                            <div class="book-card">
                                <div class="book-card-top">
                                    <div class="book-card-icon">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                                    </div>
                                    <h5 class="book-card-title">@book.Title</h5>
                                </div>
                                <div class="book-card-meta">
                                    <div class="book-meta-item">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                        <span>@FormatSize(book.FileSizeBytes)</span>
                                    </div>
                                    <div class="book-meta-item">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                                        <span>@book.PageCount pages</span>
                                    </div>
                                </div>
                                <a href="/shop/viewer/@book.Id" class="btn btn-primary btn-sm w-100" target="_blank">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                    Open & Print
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private List<BoardGroup>? booksByBoard;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);

            if (user?.ShopId == null)
            {
                error = "Your account is not linked to any shop.";
                return;
            }

            var assignments = await Db.ShopBookAssignments
                .Where(a => a.ShopId == user.ShopId && a.IsActive)
                .Include(a => a.Book)
                    .ThenInclude(b => b.Board)
                .Where(a => a.Book.IsActive)
                .ToListAsync<ShopBookAssignment>();

            booksByBoard = assignments
                .GroupBy(a => a.Book.Board.Name)
                .Select(g => new BoardGroup
                {
                    BoardName = g.Key,
                    Books = g.Select(a => a.Book).ToList()
                })
                .ToList();
        }
        catch (Exception ex)
        {
            error = $"Error loading books: {ex.Message}";
        }
    }

    private static string FormatSize(long bytes)
    {
        return bytes switch
        {
            >= 1_000_000 => $"{bytes / 1_000_000.0:F1} MB",
            >= 1_000 => $"{bytes / 1_000.0:F1} KB",
            _ => $"{bytes} B"
        };
    }

    private class BoardGroup
    {
        public string BoardName { get; set; } = "";
        public List<Book> Books { get; set; } = new();
    }
}

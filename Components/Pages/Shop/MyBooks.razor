@page "/shop/mybooks"
@attribute [Authorize(Roles = "Shop")]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>My Assigned Books</h1>
            <p class="page-subtitle">Browse and print books assigned to your shop</p>
        </div>
    </div>

    @if (error != null)
    {
        <div class="alert alert-danger">@error</div>
    }

    @if (booksByBoard == null)
    {
        <div class="loading-placeholder">Loading your books...</div>
    }
    else if (!booksByBoard.Any())
    {
        <div class="alert alert-info">
            No books have been assigned to your shop yet. Please contact the administrator.
        </div>
    }
    else
    {
        @foreach (var group in booksByBoard)
        {
            <div class="content-card mb-4">
                <div class="card-header">
                    <h4 class="mb-0">@group.BoardName</h4>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var book in group.Books)
                        {
                            <div class="col-md-4 col-lg-3">
                                <div class="card h-100 border">
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                                            </svg>
                                        </div>
                                        <h5 class="card-title mb-1">@book.Title</h5>
                                        <p class="card-text text-muted small flex-grow-1 mb-2">
                                            @book.PageCount pages
                                        </p>
                                        <a href="/shop/viewer/@book.Id" class="btn btn-primary btn-sm w-100" target="_blank">
                                            Open & Print
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<BoardGroup>? booksByBoard;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);

            if (user?.ShopId == null)
            {
                error = "Your account is not linked to any shop.";
                return;
            }

            var assignments = await Db.ShopBookAssignments
                .Where(a => a.ShopId == user.ShopId && a.IsActive)
                .Include(a => a.Book)
                    .ThenInclude(b => b.Board)
                .Where(a => a.Book.IsActive)
                .ToListAsync<ShopBookAssignment>();

            booksByBoard = assignments
                .GroupBy(a => a.Book.Board.Name)
                .Select(g => new BoardGroup
                {
                    BoardName = g.Key,
                    Books = g.Select(a => a.Book).ToList()
                })
                .ToList();
        }
        catch (Exception ex)
        {
            error = $"Error loading books: {ex.Message}";
        }
    }

    private class BoardGroup
    {
        public string BoardName { get; set; } = "";
        public List<Book> Books { get; set; } = new();
    }
}
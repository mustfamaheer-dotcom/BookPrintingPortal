@page "/shop/history"
@attribute [Authorize(Roles = "Shop")]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject PrintLoggingService PrintLogging

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>My Print History</h1>
            <p class="page-subtitle">View your shop's printing activity</p>
        </div>
    </div>

    @if (logs == null)
    {
        <div class="loading-placeholder">Loading...</div>
    }
    else if (!logs.Any())
    {
        <div class="alert alert-info">No print activity yet.</div>
    }
    else
    {
        <div class="content-card">
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Date/Time</th>
                                <th>Book</th>
                                <th>Copies</th>
                                <th>User</th>
                                <th>IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in logs)
                            {
                                <tr>
                                    <td>@log.PrintedAt.ToLocalTime().ToString("g")</td>
                                    <td><strong>@log.BookTitle</strong></td>
                                    <td><strong>@log.Copies</strong></td>
                                    <td>@log.PrintedByUserName</td>
                                    <td><code>@log.IPAddress</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-transparent">
                    <p class="text-muted mb-0">Total prints: <strong>@logs.Sum(l => l.Copies)</strong></p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<PrintLog>? logs;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user?.ShopId != null)
            logs = await PrintLogging.GetShopLogsAsync(user.ShopId.Value, 200);
    }
}
@page "/shop/history"
@attribute [Authorize(Roles = "Shop")]
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject PrintLoggingService PrintLogging

<div class="content-area">
    <div class="page-header">
        <div>
            <h1>My Print History</h1>
            <p class="page-subtitle">View your shop's printing activity</p>
        </div>
        @if (logs != null && logs.Any())
        {
            <div class="page-header-actions">
                <div class="summary-chip">
                    <span>Total: <strong>@logs.Sum(l => l.Copies)</strong> copies</span>
                </div>
            </div>
        }
    </div>

    @if (logs == null)
    {
        <div class="loading-placeholder">Loading...</div>
    }
    else if (!logs.Any())
    {
        <div class="empty-state py-5">
            <div class="empty-icon mb-3">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--gray-300)" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h5 class="text-muted">No Print Activity</h5>
            <p>Your shop hasn't printed any books yet.</p>
        </div>
    }
    else
    {
        <div class="content-card">
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Date/Time</th>
                                <th>Book</th>
                                <th>Copies</th>
                                <th>Printed By</th>
                                <th>IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in logs)
                            {
                                <tr>
                                    <td class="text-muted">@log.PrintedAt.ToEgyptLocal().ToString("g")</td>
                                    <td><strong>@log.BookTitle</strong></td>
                                    <td><span class="count-badge">@log.Copies</span></td>
                                    <td>@log.PrintedByUserName</td>
                                    <td><code class="ip-badge">@log.IPAddress</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<PrintLog>? logs;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user?.ShopId != null)
            logs = await PrintLogging.GetShopLogsAsync(user.ShopId.Value, 200);
    }
}

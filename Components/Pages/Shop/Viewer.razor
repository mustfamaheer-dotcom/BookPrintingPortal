@page "/shop/viewer/{BookId:int}"
@attribute [Authorize(Roles = "Shop")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (!authorized)
{
    <div class="viewer-unauthorized">
        <div class="unauthorized-card">
            <div class="unauthorized-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <h2>Access Restricted</h2>
            <p>You don't have permission to view this book.</p>
            <a href="/shop/mybooks" class="unauthorized-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Back to My Books
            </a>
        </div>
    </div>
}
else
{
    <div class="viewer-layout">
        <header class="viewer-header">
            <div class="viewer-header-inner">
                <div class="viewer-brand">
                    <a href="/shop/mybooks" class="viewer-back" title="Back to My Books">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    </a>
                    <div class="viewer-book-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        </svg>
                    </div>
                    <div class="viewer-title-block">
                        <span class="viewer-eyebrow">@shopName</span>
                        <h1 class="viewer-title">@bookTitle</h1>
                    </div>
                </div>

                <div class="viewer-toolbar">
                    <div class="copies-control">
                        <label for="copiesInput">Copies</label>
                        <div class="copies-input-wrap">
                            <button type="button" class="copies-btn" id="copiesDec" aria-label="Decrease copies">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            </button>
                            <input type="number" class="copies-input" id="copiesInput" value="1" min="1" max="100" />
                            <button type="button" class="copies-btn" id="copiesInc" aria-label="Increase copies">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            </button>
                        </div>
                    </div>
                    <button class="print-btn" id="printBtn" onclick="handlePrint(event, @BookId)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/>
                        </svg>
                        <span>Print</span>
                    </button>
                </div>
            </div>
        </header>

        <div class="pdf-container" id="pdfContainer">
            <div id="pdfViewer" class="pdf-canvas-container">
                <div class="pdf-loading" id="pdfLoading">
                    <div class="pdf-loading-card">
                        <div class="pdf-spinner"></div>
                        <span class="pdf-loading-text">Loading document...</span>
                        <div class="pdf-loading-bar"><span></span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Print Result Modal -->
    <div class="modal fade print-modal" id="printResultModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body print-modal-body" id="printModalBody">
                    <!-- IN-PROGRESS state -->
                    <div id="printModalStateProgress" class="print-modal-state">
                        <div class="print-modal-spinner"></div>
                        <h4 class="print-modal-title">Book is being printed now</h4>
                        <p class="print-modal-message">Sending your print job to the local printer agent…<br/>Please wait, this usually takes a few seconds.</p>
                        <div class="print-job-meta">
                            <span class="meta-pill"><span class="meta-dot meta-dot-progress"></span>Processing</span>
                        </div>
                    </div>

                    <!-- SUCCESS state -->
                    <div id="printModalStateSuccess" class="print-modal-state d-none">
                        <div class="print-modal-icon print-modal-icon-success">
                            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                            </svg>
                        </div>
                        <h4 class="print-modal-title">Print job sent successfully</h4>
                        <p class="print-modal-message">
                            The local printer agent has claimed your job and the book is now being printed on the configured printer.
                        </p>
                        <div class="print-job-meta">
                            <span class="meta-pill"><span class="meta-dot meta-dot-success"></span>Agent picked up</span>
                            <span class="meta-pill"><span class="meta-dot meta-dot-success"></span>Job removed from queue</span>
                        </div>
                        <button type="button" class="print-modal-close print-modal-close-primary" data-bs-dismiss="modal">Done</button>
                    </div>

                    <!-- ERROR state -->
                    <div id="printModalStateError" class="print-modal-state d-none">
                        <div class="print-modal-icon print-modal-icon-error">
                            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                            </svg>
                        </div>
                        <h4 class="print-modal-title">Print could not be started</h4>
                        <p class="print-modal-message">The server could not start the print job. See the details below.</p>
                        <div class="print-error-box">
                            <div class="print-error-row">
                                <span class="print-error-label">Reason</span>
                                <span class="print-error-value" id="printErrorReason">Unknown error</span>
                            </div>
                        </div>
                        <div class="print-help-box">
                            <div class="print-help-title">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                What to check
                            </div>
                            <ul class="print-help-list" id="printHelpList">
                                <li>Make sure the <strong>local printer agent</strong> is running on your computer.</li>
                                <li>Confirm you are signed in with the same account that opened the portal.</li>
                                <li>Check that the printer is online and has paper.</li>
                                <li>If the problem persists, contact your administrator.</li>
                            </ul>
                        </div>
                        <div class="print-modal-actions">
                            <button type="button" class="print-modal-close" data-bs-dismiss="modal">Close</button>
                            <button type="button" class="print-modal-close print-modal-close-primary" id="printRetryBtn">Try again</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int BookId { get; set; }

    private string? bookTitle;
    private string? shopName;
    private bool authorized;

    protected override async Task OnInitializedAsync()
    {
        var book = await Db.Books.FindAsync(BookId);
        if (book == null)
        {
            Navigation.NavigateTo("/shop/mybooks");
            return;
        }

        bookTitle = book.Title;

        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        shopName = user?.FullName ?? "User";

        if (user?.ShopId == null)
        {
            authorized = false;
            return;
        }

        var hasAccess = await Db.ShopBookAssignments
            .AnyAsync(a => a.ShopId == user.ShopId && a.BookId == BookId && a.IsActive);

        if (!hasAccess)
        {
            authorized = false;
            return;
        }

        authorized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && authorized)
        {
            await JS.InvokeVoidAsync("initPdfViewer", BookId);
        }
    }
}

@page "/shop/viewer/{BookId:int}"
@attribute [Authorize(Roles = "Shop")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation


@if (!authorized)
{
    <div class="container mt-5">
        <div class="alert alert-danger">You do not have access to this book.</div>
        <a href="/shop/mybooks" class="btn btn-primary">Go Back</a>
    </div>
}
else
{
    <div class="viewer-layout">
        <header class="viewer-header">
            <div class="d-flex align-items-center justify-content-between px-3">
                <div class="d-flex align-items-center gap-3">
                    <a href="/shop/mybooks" class="btn btn-outline-light btn-sm">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                        </svg>
                        Back
                    </a>
                    <span class="viewer-title">@bookTitle</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-light small">@shopName</span>
                    <div class="input-group input-group-sm" style="width: 130px;">
                        <span class="input-group-text">Copies</span>
                        <input type="number" class="form-control form-control-sm" @bind="copies" min="1" max="100" />
                    </div>
                    <button class="btn btn-danger btn-sm" onclick="handlePrint(event, @BookId)">
                        Print
                    </button>
                </div>
            </div>
        </header>

            <div class="pdf-container">
                <iframe id="pdfViewer"
                        src="@pdfUrl"
                        class="pdf-frame">
                </iframe>
                <div class="pdf-overlay" id="pdfOverlay"></div>
            </div>
        </div>
    }


@code {
    [Parameter] public int BookId { get; set; }

    private string? bookTitle;
    private string? shopName;
    private string? pdfUrl;
    private int copies = 1;
    private bool authorized;

    protected override async Task OnInitializedAsync()
    {
        var book = await Db.Books.FindAsync(BookId);
        if (book == null)
        {
            Navigation.NavigateTo("/shop/mybooks");
            return;
        }

        bookTitle = book.Title;

        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        shopName = user?.FullName ?? "User";

        if (user?.ShopId == null)
        {
            authorized = false;
            return;
        }

        var hasAccess = await Db.ShopBookAssignments
            .AnyAsync(a => a.ShopId == user.ShopId && a.BookId == BookId && a.IsActive);

        if (!hasAccess)
        {
            authorized = false;
            return;
        }

        authorized = true;
        pdfUrl = Navigation.ToAbsoluteUri($"/api/pdf/view/{BookId}").ToString() + "#toolbar=0&navpanes=0&scrollbar=0";
    }


}
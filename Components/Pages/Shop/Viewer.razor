@page "/shop/viewer/{BookId:int}"
@attribute [Authorize(Roles = "Shop")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (!authorized)
{
    <div class="container mt-5">
        <div class="alert alert-danger">You do not have access to this book.</div>
        <a href="/shop/mybooks" class="btn btn-primary">Go Back</a>
    </div>
}
else
{
    <div class="viewer-layout">
        <header class="viewer-header">
            <div class="d-flex align-items-center justify-content-between px-3">
                <div class="d-flex align-items-center gap-3">
                    <a href="/shop/mybooks" class="btn btn-outline-light btn-sm">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                        </svg>
                        Back
                    </a>
                    <span class="viewer-title">@bookTitle</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-light small">@shopName</span>
                    <div class="input-group input-group-sm" style="width: 130px;">
                        <span class="input-group-text">Copies</span>
                        <input type="number" class="form-control form-control-sm" id="copiesInput" value="1" min="1" max="100" />
                    </div>
                    <button class="btn btn-danger btn-sm" id="printBtn" onclick="handlePrint(event, @BookId)">
                        Print
                    </button>
                </div>
            </div>
        </header>

        <div class="pdf-container" id="pdfContainer">
            <div id="pdfViewer" class="pdf-canvas-container">
                <div class="pdf-loading" id="pdfLoading">
                    <div class="loading-spinner mb-2"></div>
                    <span>Loading document...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Print Result Modal -->
    <div class="modal fade" id="printResultModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title" id="printModalTitle">Print Status</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <div id="printModalIcon" class="mb-3">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#28a745" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/>
                        </svg>
                    </div>
                    <p id="printModalMessage" class="mb-0 fs-6">Processing your print job...</p>
                </div>
                <div class="modal-footer border-0 pt-0 justify-content-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int BookId { get; set; }

    private string? bookTitle;
    private string? shopName;
    private bool authorized;

    protected override async Task OnInitializedAsync()
    {
        var book = await Db.Books.FindAsync(BookId);
        if (book == null)
        {
            Navigation.NavigateTo("/shop/mybooks");
            return;
        }

        bookTitle = book.Title;

        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        shopName = user?.FullName ?? "User";

        if (user?.ShopId == null)
        {
            authorized = false;
            return;
        }

        var hasAccess = await Db.ShopBookAssignments
            .AnyAsync(a => a.ShopId == user.ShopId && a.BookId == BookId && a.IsActive);

        if (!hasAccess)
        {
            authorized = false;
            return;
        }

        authorized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && authorized)
        {
            await JS.InvokeVoidAsync("initPdfViewer", BookId);
        }
    }
}

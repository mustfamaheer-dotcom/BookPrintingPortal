@page "/login"
@layout PublicLayout
@inject IHttpContextAccessor HttpContextAccessor

<div class="login-page">

    @* — split background panels — *@
    <div class="login-left-panel" aria-hidden="true">
        <div class="llp-overlay"></div>
        <div class="llp-content">
            <div class="llp-brand">
                <div class="llp-brand-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </div>
                <div>
                    <div class="llp-brand-name">PrintingBooks</div>
                    <div class="llp-brand-sub">Management Portal</div>
                </div>
            </div>

            <div class="llp-headline">
                <h1>Manage your<br><span>printing workflow</span><br>smarter.</h1>
                <p>Centralised book management, secure print access and real-time analytics — all in one place.</p>
            </div>

            <div class="llp-features">
                <div class="llp-feature">
                    <div class="llp-feature-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                    </div>
                    <div>
                        <div class="llp-feature-title">Book Management</div>
                        <div class="llp-feature-desc">Upload, organise and assign books by board</div>
                    </div>
                </div>
                <div class="llp-feature">
                    <div class="llp-feature-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                            <line x1="8" y1="21" x2="16" y2="21"/>
                            <line x1="12" y1="17" x2="12" y2="21"/>
                        </svg>
                    </div>
                    <div>
                        <div class="llp-feature-title">Secure Printing</div>
                        <div class="llp-feature-desc">Every print tracked, logged and protected</div>
                    </div>
                </div>
                <div class="llp-feature">
                    <div class="llp-feature-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3v18h18"/>
                            <path d="m19 9-5 5-4-4-3 3"/>
                        </svg>
                    </div>
                    <div>
                        <div class="llp-feature-title">Analytics</div>
                        <div class="llp-feature-desc">Real-time stats across all shops</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* — form panel — *@
    <div class="login-right-panel">
        <div class="login-form-wrap">

            @* mobile logo (hidden on lg) *@
            <div class="login-mobile-brand d-flex d-lg-none align-items-center gap-3 mb-5">
                <div class="llp-brand-icon" style="width:40px;height:40px;border-radius:10px;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </div>
                <div>
                    <div style="font-weight:700;font-size:1rem;color:var(--gray-900)">PrintingBooks</div>
                    <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--gray-400)">Management Portal</div>
                </div>
            </div>

            <div class="login-form-header">
                <h2>Welcome back</h2>
                <p>Sign in to continue to your dashboard</p>
            </div>

            @{
                var error = HttpContextAccessor.HttpContext?.Request.Query["error"].FirstOrDefault();
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="login-alert">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    <span>@error</span>
                </div>
            }

            <form method="post" action="/api/login" class="login-form" autocomplete="on">
                <div class="lf-field">
                    <label for="email">Email address</label>
                    <div class="lf-input-wrap">
                        <span class="lf-input-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </span>
                        <input type="email" name="email" id="email"
                               class="lf-input" placeholder="you@example.com"
                               autocomplete="email" required />
                    </div>
                </div>

                <div class="lf-field">
                    <label for="password">Password</label>
                    <div class="lf-input-wrap">
                        <span class="lf-input-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </span>
                        <input type="password" name="password" id="password"
                               class="lf-input" placeholder="••••••••"
                               autocomplete="current-password" required />
                    </div>
                </div>

                <div class="lf-options">
                    <label class="lf-remember">
                        <input type="checkbox" name="rememberMe" value="true" />
                        <span>Remember me</span>
                    </label>
                </div>

                <button type="submit" class="lf-submit">
                    <span>Sign In</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                </button>
            </form>

            <p class="login-footer-note">&copy; @DateTime.Now.Year PrintingBooks Portal</p>
        </div>
    </div>
</div>

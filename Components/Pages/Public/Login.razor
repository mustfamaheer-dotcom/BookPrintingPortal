@page "/login"
@layout LoginLayout
@inject IHttpContextAccessor HttpContextAccessor

<div class="lp-shell">

    <!-- ════════════════════════════════════════
         LEFT  — branding panel
    ════════════════════════════════════════ -->
    <aside class="lp-brand-panel">

        <!-- animated background layers -->
        <div class="lp-bp-grid"></div>
        <div class="lp-bp-glow lp-bp-glow-1"></div>
        <div class="lp-bp-glow lp-bp-glow-2"></div>

        <div class="lp-bp-inner">

            <!-- logo -->
            <div class="lp-logo">
                <div class="lp-logo-icon">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
                         stroke="white" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </div>
                <div>
                    <div class="lp-logo-name">PrintingBooks</div>
                    <div class="lp-logo-sub">Management Portal</div>
                </div>
            </div>

            <!-- headline -->
            <div class="lp-tagline">
                <h1>
                    Smarter printing,<br>
                    <span class="lp-gradient-text">from one place.</span>
                </h1>
                <p>Centralised book management, secure access controls and
                   real-time analytics for every shop in your network.</p>
            </div>

            <!-- feature pills -->
            <div class="lp-features">

                <div class="lp-feat">
                    <span class="lp-feat-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                    </span>
                    <div>
                        <div class="lp-feat-title">Book Management</div>
                        <div class="lp-feat-desc">Upload and assign books by board</div>
                    </div>
                </div>

                <div class="lp-feat">
                    <span class="lp-feat-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </span>
                    <div>
                        <div class="lp-feat-title">Secure Printing</div>
                        <div class="lp-feat-desc">Every print tracked and protected</div>
                    </div>
                </div>

                <div class="lp-feat">
                    <span class="lp-feat-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3v18h18"/>
                            <path d="m19 9-5 5-4-4-3 3"/>
                        </svg>
                    </span>
                    <div>
                        <div class="lp-feat-title">Analytics</div>
                        <div class="lp-feat-desc">Real-time stats across all shops</div>
                    </div>
                </div>

            </div>

            <!-- bottom credit -->
            <p class="lp-bp-credit">&copy; @DateTime.Now.Year PrintingBooks Portal</p>

        </div>
    </aside>

    <!-- ════════════════════════════════════════
         RIGHT — form panel
    ════════════════════════════════════════ -->
    <main class="lp-form-panel">
        <div class="lp-form-wrap">

            <!-- mobile-only logo -->
            <div class="lp-mobile-logo">
                <div class="lp-logo-icon" style="width:38px;height:38px;border-radius:10px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="white" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </div>
                <div>
                    <div style="font-weight:700;font-size:0.95rem;color:var(--gray-900)">PrintingBooks</div>
                    <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:.07em;color:var(--gray-400)">Management Portal</div>
                </div>
            </div>

            <!-- heading -->
            <div class="lp-form-head">
                <h2>Welcome back</h2>
                <p>Sign in to access your dashboard</p>
            </div>

            <!-- error banner -->
            @{
                var error = HttpContextAccessor.HttpContext?.Request.Query["error"].FirstOrDefault();
            }
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="lp-error-banner">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    <span>@error</span>
                </div>
            }

            <!-- form -->
            <form method="post" action="/api/login" autocomplete="on">

                <div class="lp-field">
                    <label for="email">Email address</label>
                    <div class="lp-input-group">
                        <span class="lp-input-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </span>
                        <input type="email" id="email" name="email"
                               class="lp-input"
                               placeholder="you@example.com"
                               autocomplete="email" required />
                    </div>
                </div>

                <div class="lp-field">
                    <label for="password">Password</label>
                    <div class="lp-input-group">
                        <span class="lp-input-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </span>
                        <input type="password" id="password" name="password"
                               class="lp-input"
                               placeholder="••••••••"
                               autocomplete="current-password" required />
                    </div>
                </div>

                <div class="lp-extras">
                    <label class="lp-remember">
                        <input type="checkbox" name="rememberMe" value="true" />
                        <span>Keep me signed in</span>
                    </label>
                </div>

                <button type="submit" class="lp-submit">
                    Sign In
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                </button>

            </form>

        </div>
    </main>

</div>

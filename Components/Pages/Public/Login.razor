@page "/login"
@layout PublicLayout
@inject IHttpContextAccessor HttpContextAccessor

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4">PrintingBooks Portal</h3>
                    <h5 class="text-center text-muted mb-4">Sign In</h5>

                    @{
                        var error = HttpContextAccessor.HttpContext?.Request.Query["error"].FirstOrDefault();
                    }

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-danger">@error</div>
                    }

                    <form method="post" action="/login-check">
                        <div class="mb-3">
                            <label class="form-label" for="email">Email</label>
                            <input type="email" name="email" id="email" class="form-control" placeholder="Enter email" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="password">Password</label>
                            <input type="password" name="password" id="password" class="form-control" placeholder="Enter password" required />
                        </div>
                        <div class="mb-3 form-check">
                            <input type="checkbox" name="rememberMe" id="remember" class="form-check-input" value="true" />
                            <label class="form-check-label" for="remember">Remember me</label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Sign In</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

<div class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
        </div>
        <div class="brand-text">
            <div class="brand-title">PrintingBooks</div>
            <div class="brand-subtitle">MANAGEMENT PORTAL</div>
        </div>
    </div>

    <div class="sidebar-search">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" class="search-input" placeholder="Search pages..." @bind="searchQuery" @bind:event="oninput" />
        <kbd class="search-shortcut">Ctrl+K</kbd>
    </div>

    <div class="sidebar-section">
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="section-title">ADMIN PANEL</div>

                <nav class="nav-menu">
                    <NavLink class="nav-item" href="/admin/dashboard" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>
                        </svg>
                        <span>Dashboard</span>
                    </NavLink>

                    <NavLink class="nav-item" href="/admin/boards" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="18" x="3" y="3" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
                        </svg>
                        <span>Boards</span>
                    </NavLink>

                    <NavLink class="nav-item" href="/admin/books" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        </svg>
                        <span>Books</span>
                    </NavLink>

                    <NavLink class="nav-item" href="/admin/shops" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/>
                        </svg>
                        <span>Shops</span>
                    </NavLink>

                    <NavLink class="nav-item" href="/admin/assignments" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        <span>Assignments</span>
                    </NavLink>

                    <NavLink class="nav-item" href="/admin/analytics" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
                        </svg>
                        <span>Analytics</span>
                    </NavLink>
                </nav>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Shop">
            <Authorized>
                <div class="section-title">BOOKSHOP PORTAL</div>

                <nav class="nav-menu">
                    <NavLink class="nav-item" href="/shop/mybooks" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        </svg>
                        <span>My Books</span>
                    </NavLink>

                    <NavLink class="nav-item" href="/shop/history" Match="NavLinkMatch.Prefix">
                        <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                        </svg>
                        <span>Print History</span>
                    </NavLink>
                </nav>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="sidebar-bottom">
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
            <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span>Home</span>
        </NavLink>
    </div>
</div>

@code {
    private string searchQuery = "";
}

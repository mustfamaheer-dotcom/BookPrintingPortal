@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

<div class="sidebar-brand">
    <a href="/" class="brand-link">
        <div class="brand-icon">
            <svg width="22" height="22" viewBox="0 0 32 32" fill="none">
                <rect width="32" height="32" rx="8" fill="url(#brandGrad)"/>
                <path d="M8 11h16v2H8zm0 5h12v2H8zm0 5h14v2H8z" fill="white"/>
                <defs><linearGradient id="brandGrad" x1="0" y1="0" x2="32" y2="32"><stop stop-color="#3b82f6"/><stop offset="1" stop-color="#8b5cf6"/></linearGradient></defs>
            </svg>
        </div>
        <div class="brand-text">
            <span class="brand-name">PrintingBooks</span>
            <span class="brand-sub">Management Portal</span>
        </div>
    </a>
</div>

<div class="sidebar-search">
    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" class="search-input" placeholder="Search..." @bind="searchQuery" @bind:event="oninput" />
</div>

<div class="sidebar-nav">
    <AuthorizeView Roles="Admin">
        <Authorized>
            <div class="nav-section">
                <span class="nav-section-dot"></span>
                <span class="nav-section-label">Admin Panel</span>
            </div>
            <NavLink class="nav-item" href="/admin/dashboard" Match="NavLinkMatch.Prefix" title="Dashboard">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                    </svg>
                </span>
                <span class="nav-item-label">Dashboard</span>
            </NavLink>
            <NavLink class="nav-item" href="/admin/boards" Match="NavLinkMatch.Prefix" title="Boards">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
                    </svg>
                </span>
                <span class="nav-item-label">Boards</span>
            </NavLink>
            <NavLink class="nav-item" href="/admin/books" Match="NavLinkMatch.Prefix" title="Books">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </span>
                <span class="nav-item-label">Books</span>
            </NavLink>
            <NavLink class="nav-item" href="/admin/shops" Match="NavLinkMatch.Prefix" title="Shops">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </span>
                <span class="nav-item-label">Shops</span>
            </NavLink>
            <NavLink class="nav-item" href="/admin/assignments" Match="NavLinkMatch.Prefix" title="Assignments">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/>
                    </svg>
                </span>
                <span class="nav-item-label">Assignments</span>
            </NavLink>
            <NavLink class="nav-item" href="/admin/analytics" Match="NavLinkMatch.Prefix" title="Analytics">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                </span>
                <span class="nav-item-label">Analytics</span>
            </NavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Shop">
        <Authorized>
            <div class="nav-section">
                <span class="nav-section-dot"></span>
                <span class="nav-section-label">Bookshop Portal</span>
            </div>
            <NavLink class="nav-item" href="/shop/mybooks" Match="NavLinkMatch.Prefix" title="My Books">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </span>
                <span class="nav-item-label">My Books</span>
            </NavLink>
            <NavLink class="nav-item" href="/shop/history" Match="NavLinkMatch.Prefix" title="Print History">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                </span>
                <span class="nav-item-label">Print History</span>
            </NavLink>
        </Authorized>
    </AuthorizeView>
</div>

<div class="sidebar-footer">
    <NavLink class="nav-item" href="" Match="NavLinkMatch.All" title="Home">
        <span class="nav-item-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
        </span>
        <span class="nav-item-label">Home</span>
    </NavLink>
</div>

@code {
    private string searchQuery = "";
}

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

<div class="sidebar">
    <div class="navbar-brand">
        <div class="brand-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
        </div>
        <div class="brand-text">
            <span class="brand-title">PrintingBooks</span>
            <span class="brand-subtitle">Management Portal</span>
        </div>
    </div>

    <div class="search-container">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" class="search-input" placeholder="Search..." @bind="searchQuery" @bind:event="oninput" />
    </div>

    <nav>
        @foreach (var group in NavGroups)
        {
            <AuthorizeView Roles="@group.Roles">
                <Authorized>
                    @foreach (var item in group.Items)
                    {
                        <NavLink class="nav-link" href="@item.Href" Match="@item.Match">
                            <span class="nav-icon">@((MarkupString)item.IconSvg)</span>
                            <span class="nav-label">@item.Label</span>
                        </NavLink>
                    }
                </Authorized>
            </AuthorizeView>
        }
    </nav>

    <div class="sidebar-footer">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <span class="nav-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
            </span>
            <span class="nav-label">Home</span>
        </NavLink>
    </div>
</div>

@code {
    private string searchQuery = "";

    private record NavItem(string Label, string Href, string IconSvg, NavLinkMatch Match);

    private record NavGroup(string Roles, NavItem[] Items);

    private static readonly NavGroup[] NavGroups =
    [
        new("Admin",
        [
            new("Dashboard", "/admin/dashboard", SvgIcons.Dashboard, NavLinkMatch.Prefix),
            new("Boards", "/admin/boards", SvgIcons.Boards, NavLinkMatch.Prefix),
            new("Books", "/admin/books", SvgIcons.Books, NavLinkMatch.Prefix),
            new("Shops", "/admin/shops", SvgIcons.Shops, NavLinkMatch.Prefix),
            new("Assignments", "/admin/assignments", SvgIcons.Assignments, NavLinkMatch.Prefix),
            new("Analytics", "/admin/analytics", SvgIcons.Analytics, NavLinkMatch.Prefix),
        ]),
        new("Shop",
        [
            new("My Books", "/shop/mybooks", SvgIcons.Books, NavLinkMatch.Prefix),
            new("Print History", "/shop/history", SvgIcons.History, NavLinkMatch.Prefix),
        ]),
    ];

    private static class SvgIcons
    {
        public const string Dashboard = """
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/>
            </svg>
            """;

        public const string Boards = """
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
            """;

        public const string Books = """
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            """;

        public const string Shops = """
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/>
            </svg>
            """;

        public const string Assignments = """
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            """;

        public const string Analytics = """
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
            </svg>
            """;

        public const string History = """
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            """;
    }
}

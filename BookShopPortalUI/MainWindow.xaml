<Window x:Class="BookShopPortalUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DR Bahig Books Portal"
        Width="420" Height="200"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        ResizeMode="CanMinimize"
        Background="#2c3e50">
    <Border CornerRadius="6" Background="#2c3e50" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontSize="18" FontWeight="Bold" Foreground="#f39c12" TextAlignment="Center">DR Bahig Books Portal</TextBlock>

            <TextBlock x:Name="statusMessage" Grid.Row="1" FontSize="13" Foreground="White" TextAlignment="Center"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,10">
                Initializing...
            </TextBlock>

            <TextBlock x:Name="detailMessage" Grid.Row="2" FontSize="11" Foreground="#95a5a6" TextAlignment="Center" TextWrapping="Wrap" />

            <TextBlock x:Name="hintMessage" Grid.Row="3" FontSize="10" Foreground="#7f8c8d" TextAlignment="Center" Margin="0,6,0,0"
                       Visibility="Collapsed">
                Minimized to system tray. Double-click tray icon to reopen.
            </TextBlock>
        </Grid>
    </Border>
</Window>
